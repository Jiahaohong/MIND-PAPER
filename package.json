{
  "name": "mind-paper",
  "private": true,
  "version": "2.1.3",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-builder install-app-deps",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:3001 && electron .\"",
    "electron": "electron .",
    "clean:build": "node -e \"const fs=require('fs'); for (const dir of ['dist','release']) { fs.rmSync(dir,{recursive:true,force:true}); }\"",
    "build": "vite build",
    "preview": "vite preview",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:win": "npm run build && electron-builder --win",
    "pack:clean:mac": "npm run clean:build && npm run pack:mac",
    "pack:clean:win": "npm run clean:build && npm run pack:win"
  },
  "build": {
    "appId": "com.mindpaper.app",
    "productName": "Mind Paper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "!**/.DS_Store",
      "!**/Thumbs.db",
      "!**/*.log",
      "!**/*.tmp"
    ],
    "mac": {
      "icon": "assets/mind-paper-v2.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "extraResources": [
        {
          "from": "resources/qdrant/qdrant-macos",
          "to": "qdrant/qdrant-macos"
        }
      ]
    },
    "win": {
      "icon": "assets/mind-paper-v2.ico",
      "target": [
        "nsis",
        "zip"
      ],
      "extraResources": [
        {
          "from": "resources/qdrant/qdrant-win.exe",
          "to": "qdrant/qdrant-win.exe"
        }
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "keytar": "^7.9.0",
    "webdav": "^5.8.0",
    "pdfjs-dist": "4.8.69",
    "react-dom": "^19.2.4",
    "d3": "^7.9.0",
    "react": "^19.2.4",
    "react-pdf": "^9.2.1",
    "@google/genai": "^1.38.0",
    "lucide-react": "^0.563.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.0"
  }
}
